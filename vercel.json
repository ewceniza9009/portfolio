{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap.xml" },
    { "source": "/((?!api/|sitemap).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.ts": {
      "memory": 256,
      "maxDuration": 30
    }
  }
}
